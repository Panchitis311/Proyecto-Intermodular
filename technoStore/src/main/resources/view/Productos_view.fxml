<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.contrlo.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      stylesheets="/styles/styles.css"
      fx:controller="dam.code.controller.ProductoController"
      spacing="10"
      alignment="CENTER"
      styleClass="container">
    <Label text="Gestión de Productos" styleClass="title"/>
    <HBox spacing="10" alignment="CENTER">
        <Label text="Usuario" fx:id="lblUsuario"/>
        <Button text="Cerrar Sesión" onAction="#cerrarSesion" styleClass="button-close"/>
    </HBox>

    <VBox spacing="10" alignment="CENTER">
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="txtNombre" promptText="Nombre"/>
            <TextField fx:id="txtDescripcion" promptText="Descripción"/>
            <TextField fx:id="txtPrecio" promptText="Precio"/>
            <TextField fx:id="txtStock" promptText="Stock"/>
            <Button text="Añadir Producto" onAction="#addProducto"/>
        </HBox>
        <Button text="Productos" onAction="#productos" styleClass="btn-secondary"
    </VBox>

    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Id"/>
            <TableColumn fx:id="colNombre" text="Nombre"/>
            <TableColumn fx:id="colDescripcion" text="Descripción"/>
            <TableColumn fx:id="colPrecio" text="Precio"/>
            <TableColumn fx:id="colStock" text="Stock"/>
        </columns>
    </TableView>

</VBox>